@page "/system-status"
@rendermode InteractiveServer
@using TestResultBrowser.Web.Models
@using TestResultBrowser.Web.Services
@using MudBlazor
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.Extensions.Options
@inject IFileWatcherService FileWatcher
@inject ISystemStatusSummaryService SystemStatusSummaryService
@inject ITestDataService TestDataService
@inject IOptions<TestResultBrowserOptions> BrowserOptions
@inject ILogger<SystemStatus> Logger
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@implements IAsyncDisposable

<PageTitle>System Status</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">System Status & Monitoring</MudText>

@if (!string.IsNullOrWhiteSpace(realtimeStatusMessage))
{
    <MudAlert Severity="@realtimeStatusSeverity" Dense="true" Class="mb-4">
        @realtimeStatusMessage
    </MudAlert>
}

<MudGrid>
    <MudItem xs="12" md="6">
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">File Scanner Status</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudStack Spacing="2">
                    <MudText>
                        <strong>Last Scan:</strong> @(FileWatcher.LastScanTime?.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "Never")
                    </MudText>
                    <MudText>
                        <strong>Files Processed:</strong> @FileWatcher.LastScanFileCount
                    </MudText>
                    <MudText>
                        <strong>Scanning:</strong> @(FileWatcher.IsScanningInProgress ? "In Progress" : "Idle")
                    </MudText>
                    <MudText>
                        <strong>Last Duration:</strong> @GetLastScanDurationDisplay()
                    </MudText>
                    @if (!string.IsNullOrWhiteSpace(FileWatcher.LastScanError))
                    {
                        <MudAlert Severity="Severity.Warning" Dense="true">@FileWatcher.LastScanError</MudAlert>
                    }
                    @if (!string.IsNullOrWhiteSpace(reloadStatusMessage))
                    {
                        <MudAlert Severity="@reloadStatusSeverity" Dense="true">@reloadStatusMessage</MudAlert>
                    }
                </MudStack>
            </MudCardContent>
            <MudCardActions>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" 
                          OnClick="RefreshData" 
                          Disabled="@(isReloading || FileWatcher.IsScanningInProgress)">
                    @((isReloading || FileWatcher.IsScanningInProgress) ? "Reloading..." : "Reload test files")
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="RefreshSummaryAsync">
                    Refresh summary
                </MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>
    
    <MudItem xs="12" md="6">
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Cache Statistics</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                @if (!string.IsNullOrWhiteSpace(summaryError) && snapshot is null)
                {
                    <MudAlert Severity="Severity.Error">@summaryError</MudAlert>
                }
                else if (snapshot is null)
                {
                    <MudSkeleton Height="20px" Width="60%" />
                    <MudSkeleton Height="20px" Width="50%" />
                    <MudSkeleton Height="20px" Width="55%" />
                    <MudSkeleton Height="8px" Width="100%" Class="my-3" />
                }
                else
                {
                    <MudStack Spacing="2">
                        <MudText>
                            <strong>Total Test Results:</strong> @snapshot.TotalResults.ToString("N0")
                        </MudText>
                        <MudText>
                            <strong>Process Memory:</strong> @FormatBytes(snapshot.ProcessMemoryBytes)
                        </MudText>
                        <MudText>
                            <strong>Managed Heap:</strong> @FormatBytes(snapshot.ManagedMemoryBytes)
                        </MudText>
                        <MudText>
                            <strong>Reported Usage:</strong> @FormatBytes(snapshot.MemoryUsageBytes)
                        </MudText>
                        <MudText>
                            <strong>Memory %:</strong> @MemoryPercentage.ToString("N1")% of @GetConfiguredMemoryLimitLabel()
                        </MudText>
                        <MudProgressLinear Color="@GetMemoryColor()" Value="@MemoryPercentage" Class="my-2" />
                    </MudStack>
                }
            </MudCardContent>
        </MudCard>
    </MudItem>
    
    <MudItem xs="12" md="6">
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Data Coverage</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                @if (!string.IsNullOrWhiteSpace(summaryError) && snapshot is null)
                {
                    <MudAlert Severity="Severity.Warning">Coverage data is currently unavailable.</MudAlert>
                }
                else if (snapshot is null)
                {
                    <MudSkeleton Height="20px" Width="45%" />
                    <MudSkeleton Height="20px" Width="50%" />
                    <MudSkeleton Height="20px" Width="40%" />
                    <MudSkeleton Height="20px" Width="75%" />
                }
                else
                {
                    <MudStack Spacing="2">
                        <MudText>
                            <strong>Total Builds:</strong> @snapshot.TotalBuilds
                        </MudText>
                        <MudText>
                            <strong>Configurations:</strong> @snapshot.TotalConfigurations
                        </MudText>
                        <MudText>
                            <strong>Domains:</strong> @snapshot.TotalDomains
                        </MudText>
                        <MudText>
                            <strong>Date Range:</strong> @GetDateRangeDisplay()
                        </MudText>
                    </MudStack>
                }
            </MudCardContent>
        </MudCard>
    </MudItem>
    
    <MudItem xs="12" md="6">
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Recent Builds</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                @if (!string.IsNullOrWhiteSpace(summaryError) && snapshot is null)
                {
                    <MudAlert Severity="Severity.Warning">Recent builds could not be loaded.</MudAlert>
                }
                else if (snapshot is null)
                {
                    <MudSkeleton Height="18px" Width="80%" />
                    <MudSkeleton Height="18px" Width="70%" />
                    <MudSkeleton Height="18px" Width="76%" />
                }
                else if (snapshot.RecentBuilds.Any())
                {
                    <MudList T="string" Dense="true">
                        @foreach (var build in snapshot.RecentBuilds)
                        {
                            <MudListItem T="string" Icon="@Icons.Material.Filled.Build">
                                @build
                            </MudListItem>
                        }
                    </MudList>
                }
                else
                {
                    <MudText Color="Color.Secondary">No builds loaded yet</MudText>
                }
            </MudCardContent>
        </MudCard>
    </MudItem>
    
    <MudItem xs="12" md="6">
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Monitored Configurations</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                @if (!string.IsNullOrWhiteSpace(summaryError) && snapshot is null)
                {
                    <MudAlert Severity="Severity.Warning">Configuration metadata is currently unavailable.</MudAlert>
                }
                else if (snapshot is null)
                {
                    <MudSkeleton Height="18px" Width="30%" />
                    <MudSkeleton Height="28px" Width="100%" />
                    <MudSkeleton Height="18px" Width="36%" Class="mt-4" />
                    <MudSkeleton Height="28px" Width="100%" />
                }
                else
                {
                    <MudStack Spacing="3">
                        <div>
                            <MudText Typo="Typo.subtitle2"><strong>Versions:</strong></MudText>
                            @if (snapshot.Versions.Any())
                            {
                                <MudChipSet T="string">
                                    @foreach (var version in snapshot.Versions.Take(8))
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Primary">@version</MudChip>
                                    }
                                    @if (snapshot.Versions.Count > 8)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Default">+@(snapshot.Versions.Count - 8) more</MudChip>
                                    }
                                </MudChipSet>
                            }
                            else
                            {
                                <MudText Color="Color.Secondary">None</MudText>
                            }
                        </div>
                        
                        <div>
                            <MudText Typo="Typo.subtitle2"><strong>Named Configs:</strong></MudText>
                            @if (snapshot.NamedConfigs.Any())
                            {
                                <MudChipSet T="string">
                                    @foreach (var config in snapshot.NamedConfigs.Take(8))
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Secondary">@config</MudChip>
                                    }
                                    @if (snapshot.NamedConfigs.Count > 8)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Default">+@(snapshot.NamedConfigs.Count - 8) more</MudChip>
                                    }
                                </MudChipSet>
                            }
                            else
                            {
                                <MudText Color="Color.Secondary">None</MudText>
                            }
                        </div>
                    </MudStack>
                }
            </MudCardContent>
        </MudCard>
    </MudItem>
    
    <MudItem xs="12">
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Memory Management</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                @if (snapshot is null)
                {
                    <MudAlert Severity="Severity.Info">
                        System summary is loading in the background.
                    </MudAlert>
                }
                else if (MemoryPercentage > 90)
                {
                    <MudAlert Severity="Severity.Error">
                        CRITICAL: Memory usage above 90%. Consider clearing cache or increasing MaxMemoryGB limit.
                    </MudAlert>
                }
                else if (MemoryPercentage > 75)
                {
                    <MudAlert Severity="Severity.Warning">
                        WARNING: Memory usage above 75%. Monitor closely.
                    </MudAlert>
                }
                else
                {
                    <MudAlert Severity="Severity.Success">
                        Memory usage is within normal limits.
                    </MudAlert>
                }
                
                <MudText Class="mt-4">
                    <strong>Recommendations:</strong>
                </MudText>
                <MudList T="string" Dense="true">
                    @if (snapshot is null)
                    {
                        <MudListItem T="string" Icon="@Icons.Material.Filled.HourglassBottom">
                            Waiting for summary metrics
                        </MudListItem>
                    }
                    else if (MemoryPercentage > 50)
                    {
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Warning">
                            Consider archiving older test results
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Info">
                            Current rate: @snapshot.TotalResults.ToString("N0") results = @FormatBytes(snapshot.MemoryUsageBytes)
                        </MudListItem>
                    }
                    else
                    {
                        <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle">
                            System is operating efficiently
                        </MudListItem>
                    }
                </MudList>
            </MudCardContent>
            <MudCardActions>
                <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="ClearCache">
                    Clear All Cache
                </MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    private HubConnection? hubConnection;
    private int maxMemoryGB = 15; // From appsettings.json
    private SystemStatusSnapshot? snapshot;
    private string? summaryError;
    private CancellationTokenSource? summaryLoadCts;
    private bool isReloading;
    private string? reloadStatusMessage;
    private Severity reloadStatusSeverity = Severity.Info;
    private string? realtimeStatusMessage;
    private Severity realtimeStatusSeverity = Severity.Info;

    protected override Task OnInitializedAsync()
    {
        maxMemoryGB = BrowserOptions.Value.Cache.MaxMemoryGB > 0
            ? BrowserOptions.Value.Cache.MaxMemoryGB
            : BrowserOptions.Value.MaxMemoryGB;

        StartSummaryLoad();

        _ = InitializeHubConnectionAsync();

        return Task.CompletedTask;
    }

    private async Task InitializeHubConnectionAsync()
    {
        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("hubs/testdata"))
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<object>("TestDataUpdated", async (updateInfo) =>
        {
            Logger.LogInformation("Received TestDataUpdated notification from SignalR");
            StartSummaryLoad(invalidateCache: true);
            
            Snackbar.Add("✅ New test results imported!", Severity.Success, config =>
            {
                config.VisibleStateDuration = 4000;
                config.HideTransitionDuration = 400;
                config.ShowTransitionDuration = 400;
            });
            
            await InvokeAsync(StateHasChanged);
        });

        hubConnection.Reconnecting += error =>
        {
            realtimeStatusSeverity = Severity.Warning;
            realtimeStatusMessage = "Real-time updates are reconnecting. Manual reload remains available.";
            return InvokeAsync(StateHasChanged);
        };

        hubConnection.Reconnected += connectionId =>
        {
            realtimeStatusSeverity = Severity.Success;
            realtimeStatusMessage = "Real-time updates are connected.";
            return InvokeAsync(StateHasChanged);
        };

        hubConnection.Closed += error =>
        {
            realtimeStatusSeverity = Severity.Warning;
            realtimeStatusMessage = "Real-time updates are unavailable. Use Reload test files if needed.";
            return InvokeAsync(StateHasChanged);
        };

        try
        {
            await hubConnection.StartAsync();
            realtimeStatusSeverity = Severity.Success;
            realtimeStatusMessage = "Real-time updates are connected.";
            Logger.LogInformation("SignalR connection established for System Status");
        }
        catch (Exception ex)
        {
            realtimeStatusSeverity = Severity.Warning;
            realtimeStatusMessage = "Real-time updates are unavailable. The page is still usable, and Reload test files will continue to work.";
            Logger.LogWarning(ex, "SignalR connection could not be established for System Status");
        }

        await InvokeAsync(StateHasChanged);
    }

    private void StartSummaryLoad(bool invalidateCache = false)
    {
        summaryLoadCts?.Cancel();
        summaryLoadCts?.Dispose();
        summaryLoadCts = new CancellationTokenSource(TimeSpan.FromSeconds(30));

        if (invalidateCache)
        {
            SystemStatusSummaryService.Invalidate();
        }

        summaryError = null;
        _ = LoadSummaryAsync(summaryLoadCts.Token);
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task LoadSummaryAsync(CancellationToken cancellationToken)
    {
        try
        {
            snapshot = await SystemStatusSummaryService.GetSnapshotAsync(cancellationToken);
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load system status summary");
            summaryError = "System summary could not be loaded.";
        }
        finally
        {
            if (!cancellationToken.IsCancellationRequested)
            {
                await InvokeAsync(StateHasChanged);
            }
        }
    }
    
    private string GetDateRangeDisplay()
    {
        if (snapshot?.EarliestDate == null || snapshot.LatestDate == null)
            return "No data";
            
        if (snapshot.EarliestDate.Value.Date == snapshot.LatestDate.Value.Date)
            return snapshot.EarliestDate.Value.ToString("yyyy-MM-dd");
            
        return $"{snapshot.EarliestDate.Value:yyyy-MM-dd} to {snapshot.LatestDate.Value:yyyy-MM-dd}";
    }

    private Color GetMemoryColor()
    {
        if (MemoryPercentage > 90) return Color.Error;
        if (MemoryPercentage > 75) return Color.Warning;
        if (MemoryPercentage > 50) return Color.Info;
        return Color.Success;
    }

    private double MemoryUsageMB => (snapshot?.MemoryUsageBytes ?? 0) / (1024.0 * 1024.0);

    private double MemoryPercentage
    {
        get
        {
            if (snapshot == null)
            {
                return 0;
            }

            var maxMemoryBytes = maxMemoryGB * 1024L * 1024L * 1024L;
            return (snapshot.MemoryUsageBytes / (double)maxMemoryBytes) * 100;
        }
    }

    private string GetConfiguredMemoryLimitLabel() => maxMemoryGB > 0 ? $"{maxMemoryGB} GB limit" : "configured limit";

    private static string FormatBytes(long bytes)
    {
        const double scale = 1024;
        string[] suffixes = ["B", "KB", "MB", "GB", "TB"];
        var value = (double)Math.Max(bytes, 0);
        var order = 0;

        while (value >= scale && order < suffixes.Length - 1)
        {
            order++;
            value /= scale;
        }

        return $"{value:N2} {suffixes[order]}";
    }

    private string GetLastScanDurationDisplay() => FileWatcher.LastScanDuration is { } duration
        ? duration.TotalSeconds >= 1
            ? duration.ToString(@"mm\:ss")
            : $"{duration.TotalMilliseconds:N0} ms"
        : "Unknown";

    private async Task RefreshData()
    {
        if (isReloading || FileWatcher.IsScanningInProgress)
        {
            reloadStatusSeverity = Severity.Info;
            reloadStatusMessage = "A reload is already running.";
            return;
        }

        isReloading = true;
        reloadStatusMessage = null;

        try
        {
            Logger.LogInformation("Reload test files clicked. Current scanning status: {Status}", FileWatcher.IsScanningInProgress);

            var scanTask = FileWatcher.ScanNowAsync();
            var completedTask = await Task.WhenAny(scanTask, Task.Delay(TimeSpan.FromMinutes(2)));

            if (completedTask != scanTask)
            {
                reloadStatusSeverity = Severity.Info;
                reloadStatusMessage = "Reload started and is still running in the background.";
                Snackbar.Add(reloadStatusMessage, Severity.Info);
                return;
            }

            await scanTask;
            StartSummaryLoad(invalidateCache: true);

            if (!string.IsNullOrWhiteSpace(FileWatcher.LastScanError))
            {
                reloadStatusSeverity = Severity.Warning;
                reloadStatusMessage = FileWatcher.LastScanError;
                Snackbar.Add($"Reload completed with warnings: {FileWatcher.LastScanError}", Severity.Warning);
            }
            else
            {
                reloadStatusSeverity = Severity.Success;
                reloadStatusMessage = $"Reloaded {FileWatcher.LastScanFileCount:N0} file(s) in {GetLastScanDurationDisplay()}.";
                Snackbar.Add(reloadStatusMessage, Severity.Success);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Reload test files failed");
            reloadStatusSeverity = Severity.Error;
            reloadStatusMessage = "Reload test files failed.";
            Snackbar.Add($"Reload test files failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            isReloading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private Task RefreshSummaryAsync()
    {
        StartSummaryLoad(invalidateCache: true);
        reloadStatusSeverity = Severity.Info;
        reloadStatusMessage = "Refreshing summary metrics...";
        return Task.CompletedTask;
    }

    private void ClearCache()
    {
        TestDataService.Clear();
        StartSummaryLoad(invalidateCache: true);
    }

    public async ValueTask DisposeAsync()
    {
        summaryLoadCts?.Cancel();
        summaryLoadCts?.Dispose();

        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }
}
