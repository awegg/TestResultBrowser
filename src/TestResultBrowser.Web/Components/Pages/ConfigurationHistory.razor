    private List<string> BuildTriageHistoryWindow()
    {
        var maxBuilds = Math.Max(2, numberOfBuilds);
        var builds = new List<string>();

        if (!string.IsNullOrWhiteSpace(selectedCurrentBuild))
        {
            builds.Add(selectedCurrentBuild);
        }

        foreach (var baseline in selectedBaselineBuilds.OrderByDescending(BuildNumberExtractor.ExtractBuildNumber))
        {
            if (!builds.Contains(baseline, StringComparer.OrdinalIgnoreCase))
            {
                builds.Add(baseline);
            }
        }

        var oldestBaseline = selectedBaselineBuilds.Count > 0
            ? selectedBaselineBuilds.Min(BuildNumberExtractor.ExtractBuildNumber)
            : int.MaxValue;

        foreach (var build in availableBuilds
            .Where(build => !builds.Contains(build, StringComparer.OrdinalIgnoreCase))
            .Where(build => BuildNumberExtractor.ExtractBuildNumber(build) < oldestBaseline)
            .OrderByDescending(BuildNumberExtractor.ExtractBuildNumber))
        {
            if (builds.Count >= maxBuilds)
            {
                break;
            }

            builds.Add(build);
        }

        return builds.Take(maxBuilds).ToList();
    }

