    private async Task LoadFeatureSelectionPreferencesAsync()
    {
        var config = await UserDataService.GetDashboardConfigAsync(currentUsername);
        if (config == null)
        {
            return;
        }

        selectedFeatureGroups = (config.FeatureFilterGroups ?? new List<string>())
            .Where(g => !string.IsNullOrWhiteSpace(g))
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        explicitFeatureSelections = (config.FeatureFilterNames ?? new List<string>())
            .Where(f => !string.IsNullOrWhiteSpace(f))
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
    }

    private async Task SaveFeatureSelectionPreferencesAsync()
    {
        var config = await UserDataService.GetDashboardConfigAsync(currentUsername)
            ?? new DashboardConfiguration { Username = currentUsername };

        config.FeatureFilterGroups = selectedFeatureGroups
            .OrderBy(x => x, StringComparer.OrdinalIgnoreCase)
            .ToList();

        config.FeatureFilterNames = explicitFeatureSelections
            .OrderBy(x => x, StringComparer.OrdinalIgnoreCase)
            .ToList();

        await UserDataService.SaveDashboardConfigAsync(config);
    }

    private void ApplyFeatureSelectionIntentToCurrentConfiguration()
    {
        if (featureGroups.Count == 0)
        {
            selectedFeatureNames.Clear();
            return;
        }

        var knownFeatures = featureGroups
            .SelectMany(g => g.Value)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        var fromGroups = ExpandSelectedGroupFeatures();
        var fromExplicit = explicitFeatureSelections.Where(knownFeatures.Contains);

        selectedFeatureNames = fromGroups
            .Concat(fromExplicit)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
    }

    private HashSet<string> ExpandSelectedGroupFeatures()
    {
        var selected = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

        foreach (var group in selectedFeatureGroups)
        {
            if (!featureGroups.TryGetValue(group, out var features))
            {
                continue;
            }

            foreach (var feature in features)
            {
                selected.Add(feature);
            }
        }

        return selected;
    }

    private void BuildFeatureSelectionIntentFromCurrentSelection()
    {
        selectedFeatureGroups = featureGroups
            .Where(group => group.Value.Count > 0 && group.Value.All(f => selectedFeatureNames.Contains(f)))
            .Select(group => group.Key)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        var impliedByGroups = ExpandSelectedGroupFeatures();
        explicitFeatureSelections = selectedFeatureNames
            .Where(feature => !impliedByGroups.Contains(feature))
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
    }

    private async Task<ConfigurationHistoryResult> BuildTriageHistoryResultAsync()
    {
        if (triageResult == null)
        {
            return new ConfigurationHistoryResult();
        }

        if (hideFlakyTests)
        {
            await EnsureTriageFlakyTestsLoadedAsync();
        }
        else
        {
            flakyTestNames.Clear();
            flakySignature = null;
        }

        var filterBySpecificConfigurations = selectedConfigurations.Any()
            && !selectedConfigurations.Contains(ConfigurationHistoryService.AllConfigurationsId, StringComparer.OrdinalIgnoreCase);

        var buildIds = BuildTriageHistoryWindow();
        var historyColumns = buildIds
            .Select((buildId, index) => new HistoryColumn
            {
                BuildId = buildId,
                BuildTime = TestDataService.GetBuildTimestamp(buildId) ?? DateTime.UtcNow,
                ColumnIndex = index
            })
            .ToList();

        var newFailureRows = triageResult.NewFailures
            .Where(failure => !filterBySpecificConfigurations || failure.AffectedConfigs.Any(selectedConfigurations.Contains))
            .SelectMany(failure => failure.AffectedConfigs
                .Where(configId => !filterBySpecificConfigurations || selectedConfigurations.Contains(configId))
                .Select(configId => new TriageRow(failure, configId)))
            .Where(row => !hideFlakyTests || !flakyTestNames.Contains(row.Failure.TestFullName))
            .Where(row => !hideInfrastructureIssues || row.Failure.Category == MorningFailureCategory.Product)
            .Where(row => !hideAcknowledgedFailures || GetAcknowledgement(row) == null)
            .ToList();

        triageVisibleFailureCount = newFailureRows.Count;

        return selectedTriageSummaryFilter switch
        {
            TriageSummaryFilter.FixedTests => BuildTriageHistoryResultFromDisplayRows(BuildFixedTriageRows(filterBySpecificConfigurations, buildIds), buildIds, historyColumns),
            TriageSummaryFilter.StillFailing => BuildTriageHistoryResultFromDisplayRows(BuildStillFailingRows(filterBySpecificConfigurations, buildIds), buildIds, historyColumns),
            TriageSummaryFilter.MissingConfigurations => BuildTriageHistoryResultFromDisplayRows(new List<TriageDisplayRow>(), buildIds, historyColumns),
            _ => BuildTriageHistoryResultFromDisplayRows(BuildNewFailureDisplayRows(newFailureRows, buildIds), buildIds, historyColumns)
        };
    }

    private ConfigurationHistoryResult BuildTriageHistoryResultFromDisplayRows(List<TriageDisplayRow> rows, List<string> buildIds, List<HistoryColumn> historyColumns)
    {
        var filterBySpecificConfigurations = selectedConfigurations.Any()
            && !selectedConfigurations.Contains(ConfigurationHistoryService.AllConfigurationsId, StringComparer.OrdinalIgnoreCase);

        var suiteNodes = rows
            .GroupBy(row => row.ConfigurationId, StringComparer.OrdinalIgnoreCase)
            .Select(group => BuildTriageDisplaySuiteNode(group.Key, group.ToList(), buildIds))
            .OrderBy(node => node.Name, StringComparer.OrdinalIgnoreCase)
            .ToList();

        var rootNode = new HierarchyNode
        {
            Name = "Root",
            NodeType = HierarchyNodeType.Domain,
            NodeId = "triage-root",
            IndentLevel = -1,
            IsExpanded = false,
            Children = suiteNodes
        };
        PopulateAggregateNode(rootNode, buildIds.Count);

        return new ConfigurationHistoryResult
        {
            ConfigurationId = filterBySpecificConfigurations
                ? string.Join(", ", selectedConfigurations.OrderBy(x => x, StringComparer.OrdinalIgnoreCase))
                : ConfigurationHistoryService.AllConfigurationsId,
            LatestBuildId = buildIds.FirstOrDefault() ?? selectedCurrentBuild,
            LatestBuildTime = TestDataService.GetBuildTimestamp(buildIds.FirstOrDefault() ?? selectedCurrentBuild) ?? DateTime.UtcNow,
            TotalTests = rows.Count,
            PassedTests = 0,
            FailedTests = rows.Count,
            SkippedTests = 0,
            HistoryColumns = historyColumns,
            HierarchyNodes = new List<HierarchyNode> { rootNode }
        };
    }

