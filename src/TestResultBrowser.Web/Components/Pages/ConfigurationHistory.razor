    private string BuildAcknowledgementId(TriageRow row)
    {
        return $"{row.Failure.TestFullName}|{row.ConfigurationId}|{row.Failure.FailureSignature}".ToLowerInvariant();
    }

    private string BuildAcknowledgementId(TestResult result)
    {
        var failureSignature = FailureClassificationService.BuildFailureSignature(result);
        return $"{result.TestFullName}|{result.ConfigurationId}|{failureSignature}".ToLowerInvariant();
    }

