    private static TriageSummaryFilter ParseTriageSummaryFilter(string? value)
    {
        return value?.Trim().ToLowerInvariant() switch
        {
            "fixed" => TriageSummaryFilter.FixedTests,
            "still-failing" => TriageSummaryFilter.StillFailing,
            "missing-configs" => TriageSummaryFilter.MissingConfigurations,
            _ => TriageSummaryFilter.NewFailures
        };
    }

    private static string FormatTriageSummaryFilter(TriageSummaryFilter filter)
    {
        return filter switch
        {
            TriageSummaryFilter.FixedTests => "fixed",
            TriageSummaryFilter.StillFailing => "still-failing",
            TriageSummaryFilter.MissingConfigurations => "missing-configs",
            _ => "new-failures"
        };
    }

    private List<TriageDisplayRow> BuildNewFailureDisplayRows(List<TriageRow> rows, List<string> buildIds)
    {
        return rows.Select(row =>
        {
            var representativeResult = GetRepresentativeTriageResult(buildIds, row.Failure.TestFullName, row.ConfigurationId);
            var (suiteId, suiteName) = ResolveTriageSuiteInfo(representativeResult);
            var badges = new List<HierarchyNodeBadge>();
            if (row.Failure.Category != MorningFailureCategory.Product)
            {
                badges.Add(new HierarchyNodeBadge { Text = row.Failure.Category == MorningFailureCategory.Setup ? "Setup" : "Infra", Tone = HierarchyBadgeTone.Warning });
            }

            if (GetAcknowledgement(row) is { } acknowledgement)
            {
                badges.Add(new HierarchyNodeBadge { Text = $"Ack: {acknowledgement.AcknowledgedBy}", Tone = HierarchyBadgeTone.Success });
            }

            return new TriageDisplayRow(
                suiteId,
                suiteName,
                row.Failure.FeatureId,
                row.ConfigurationId,
                row.Failure.TestFullName,
                BuildTriageNodeId(row),
                row.Failure.ErrorMessage,
                row.Failure.StackTrace,
                badges,
                GetAcknowledgement(row) != null,
                "ack-toggle");
        }).ToList();
    }

    private List<TriageDisplayRow> BuildFixedTriageRows(bool filterBySpecificConfigurations, List<string> buildIds)
    {
        return triageResult?.FixedTests
            .Where(fixedTest => !filterBySpecificConfigurations || fixedTest.FixedInConfigs.Any(selectedConfigurations.Contains))
            .SelectMany(fixedTest => fixedTest.FixedInConfigs
                .Where(configId => !filterBySpecificConfigurations || selectedConfigurations.Contains(configId))
                .Select(configId =>
                {
                    var failedResult = GetFirstFailedResult(buildIds, fixedTest.TestFullName, configId);
                    var representativeResult = GetRepresentativeTriageResult(buildIds, fixedTest.TestFullName, configId) ?? failedResult;
                    var (suiteId, suiteName) = ResolveTriageSuiteInfo(representativeResult);
                    return new TriageDisplayRow(
                        suiteId,
                        suiteName,
                        fixedTest.FeatureId,
                        configId,
                        fixedTest.TestFullName,
                        $"triage-fixed:{configId}:{fixedTest.TestFullName}",
                        failedResult?.ErrorMessage,
                        failedResult?.StackTrace,
                        new List<HierarchyNodeBadge>
                        {
                            new() { Text = "Fixed", Tone = HierarchyBadgeTone.Success }
                        },
                        false,
                        null);
                }))
            .ToList() ?? new List<TriageDisplayRow>();
    }

    private List<TriageDisplayRow> BuildStillFailingRows(bool filterBySpecificConfigurations, List<string> buildIds)
    {
        return triageResult?.StillFailing
            .Where(result => !filterBySpecificConfigurations || selectedConfigurations.Contains(result.ConfigurationId))
            .Where(result => !hideFlakyTests || !flakyTestNames.Contains(result.TestFullName))
            .Select(result => new
            {
                Result = result,
                Category = FailureClassificationService.Classify(result),
                Acknowledgement = GetAcknowledgement(result)
            })
            .Where(item => !hideInfrastructureIssues || item.Category == MorningFailureCategory.Product)
            .Where(item => !hideAcknowledgedFailures || item.Acknowledgement == null)
            .Select(item =>
            {
                var (suiteId, suiteName) = ResolveTriageSuiteInfo(item.Result);
                var badges = new List<HierarchyNodeBadge>();
                if (item.Category != MorningFailureCategory.Product)
                {
                    badges.Add(new HierarchyNodeBadge { Text = item.Category == MorningFailureCategory.Setup ? "Setup" : "Infra", Tone = HierarchyBadgeTone.Warning });
                }


                if (item.Acknowledgement != null)
                {
                    badges.Add(new HierarchyNodeBadge { Text = $"Ack: {item.Acknowledgement.AcknowledgedBy}", Tone = HierarchyBadgeTone.Success });
                }

                return new TriageDisplayRow(
                    suiteId,
                    suiteName,
                    item.Result.FeatureId,
                    item.Result.ConfigurationId,
                    item.Result.TestFullName,
                    BuildStillFailingNodeId(item.Result),
                    item.Result.ErrorMessage,
                    item.Result.StackTrace,
                    badges,
                    item.Acknowledgement != null,
                    "ack-toggle");
            })
            .ToList() ?? new List<TriageDisplayRow>();
    }

    private TestResult? GetFirstFailedResult(List<string> buildIds, string testFullName, string configurationId)
    {
        foreach (var buildId in buildIds)
        {
            var result = TestDataService.GetTestResultFast(buildId, testFullName, configurationId);
            if (result?.Status == TestStatus.Fail)
            {
                return result;
            }
        }

        return null;
    }

    private TestResult? GetRepresentativeTriageResult(List<string> buildIds, string testFullName, string configurationId)
    {
        foreach (var buildId in buildIds)
        {
            var result = TestDataService.GetTestResultFast(buildId, testFullName, configurationId);
            if (result != null)
            {
                return result;
            }
        }

        return TestDataService.GetTestResultsByTestName(testFullName)
            .Where(result => string.Equals(result.ConfigurationId, configurationId, StringComparison.OrdinalIgnoreCase))
            .OrderByDescending(result => result.BuildNumber)
            .ThenByDescending(result => result.Timestamp)
            .FirstOrDefault();
    }

    private static (string SuiteId, string SuiteName) ResolveTriageSuiteInfo(TestResult? result)
    {
        if (string.IsNullOrWhiteSpace(result?.TestSuiteId))
        {
            return ("unknown", "Unknown");
        }

        return (result.TestSuiteId, result.TestSuiteId);
    }

    private static string ExtractReadableSuiteName(string suiteId)
    {
        if (string.IsNullOrWhiteSpace(suiteId))
        {
            return "Unknown";
        }

        var parts = suiteId.Split('_');
        return parts.Length > 1 ? parts[^1] : suiteId;
    }

    private HierarchyNode BuildTriageDisplaySuiteNode(string configurationId, List<TriageDisplayRow> rows, List<string> buildIds)
    {
        var featureNodes = rows
            .GroupBy(row => row.FeatureId, StringComparer.OrdinalIgnoreCase)
            .Select(group => BuildTriageDisplayFeatureNode(configurationId, group.Key, group.ToList(), buildIds))
            .OrderBy(node => node.Name, StringComparer.OrdinalIgnoreCase)
            .ToList();

        var node = new HierarchyNode
        {
            Name = ConfigurationLabelHelper.GetConfigurationLabel(configurationId),
            NodeType = HierarchyNodeType.Suite,
            NodeId = $"triage-suite:{selectedTriageSummaryFilter}:{configurationId}",
            IndentLevel = 0,
            IsExpanded = false,
            Children = featureNodes
        };
        PopulateAggregateNode(node, buildIds.Count);
        return node;
    }

    private HierarchyNode BuildTriageDisplayFeatureNode(string configurationId, string featureId, List<TriageDisplayRow> rows, List<string> buildIds)
    {
