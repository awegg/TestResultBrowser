@page "/configuration-history"
@rendermode InteractiveServer
@using TestResultBrowser.Web.Models
@using TestResultBrowser.Web.Services
@using TestResultBrowser.Web.Common
@using Microsoft.Extensions.Options
@using MudBlazor
@using Microsoft.AspNetCore.Components
@using Microsoft.JSInterop
@using TestResultBrowser.Web.Components
@inject IConfigurationHistoryService ConfigHistoryService
@inject ITriageService TriageService
@inject IUserDataService UserDataService
@inject IFeatureGroupingService FeatureGroupingService
@inject IFlakyTestDetectionService FlakyTestDetectionService
@inject IFailureClassificationService FailureClassificationService
@inject IWorkItemLinkService WorkItemLinkService
@inject IOptions<TestResultBrowserOptions> BrowserOptions
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@inject ITestDataService TestDataService

<PageTitle>@(isTriageMode ? "Triage History" : "Configuration History")</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    
    @* Compact Header Bar: config + builds + load button in one line *@
    <MudPaper Class="mb-3 pa-3">
        <div class="header-bar">
            <MudButton Variant="Variant.Outlined"
                      Color="Color.Primary"
                      OnClick="OpenConfigurationDialog"
                      Class="header-control header-config text-left"
                      Style="justify-content: flex-start;">
                <MudIcon Icon="@Icons.Material.Filled.Settings" Class="mr-2"></MudIcon>
                @if (selectedConfigurations.Count == 0)
                {
                    <span>Select configuration…</span>
                }
                else if (selectedConfigurations.Count == 1)
                {
                    <span>@ConfigurationLabelHelper.GetConfigurationLabel(selectedConfigurations.First())</span>
                }
                else
                {
                    <span>@selectedConfigurations.Count configurations selected</span>
                }
                <MudSpacer />
                <MudIcon Icon="@Icons.Material.Filled.MoreVert"></MudIcon>
            </MudButton>

            @if (isTriageMode)
            {
                <MudSelect T="string"
                           Label="Current build"
                           Dense="true"
                           Variant="Variant.Outlined"
                           Class="header-control triage-build-select"
                           Value="@selectedCurrentBuild" ValueChanged="@OnCurrentBuildChanged">
                    @foreach (var build in availableBuilds)
                    {
                        <MudSelectItem T="string" Value="@build">@build</MudSelectItem>
                    }
                </MudSelect>

                <MudMenu Variant="Variant.Outlined"
                         Color="Color.Primary"
                         Dense="true"
                         Label="@GetBaselineMenuLabel()"
                         Class="header-control triage-baseline-menu">
                    <div style="padding:0.75rem; width:340px; max-height:420px; overflow:auto;">
                        <MudTextField T="string"
                                      Value="@baselineBuildSearch"
                                      ValueChanged="OnBaselineSearchChanged"
                                      Placeholder="Search baselines"
                                      Dense="true"
                                      Variant="Variant.Outlined"
                                      Immediate="true"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Search" />
                        <div style="display:flex; gap:0.35rem; margin:0.5rem 0; flex-wrap:wrap;">
                            <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="SelectVisibleBaselineBuilds">Select visible</MudButton>
                            <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="ClearBaselineBuilds">Clear</MudButton>
                        </div>
                        @foreach (var build in GetFilteredBaselineBuildOptions())
                        {
                            <MudCheckBox T="bool"
                                         Value="@selectedBaselineBuilds.Contains(build)"
                                         ValueChanged="@(isChecked => ToggleBaselineBuild(build, isChecked))"
                                         Label="@build"
                                         Dense="true" />
                        }
                    </div>
                </MudMenu>
            }

            <MudNumericField Value="@numberOfBuilds"
                             ValueChanged="@(async (int newValue) => await OnNumberOfBuildsChanged(newValue))"
                             Min="1" Max="20"
                             Dense="true"
                             Variant="Variant.Outlined"
                             Class="header-control builds-field"
                             Placeholder="Builds" />

            <MudButton Variant="Variant.Filled"
                      Color="Color.Primary"
                      OnClick="RefreshData"
                      Disabled="@isLoading"
                      Class="header-control load-btn">
                @if (isLoading)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                }
                else
                {
                    <span>Load Data</span>
                }
            </MudButton>
        </div>
    </MudPaper>

    @* Content area (full width) *@
    <MudGrid Class="config-history-grid">
        <MudItem xs="12" md="12" Class="main-content">
            @* Quick Actions *@
            <MudPaper Class="mb-4 pa-2">
                <div class="d-flex gap-2 align-center">
                    <LoadFilterDropdown @ref="loadFilterDropdown" Username="@currentUsername" OnFilterLoaded="ApplyFilter" OnCopyLinkRequested="CopyFilterLink" />
                    <MudButton Variant="Variant.Outlined" Color="Color.Info" OnClick="OpenSaveFilterDialog" Disabled="@(historyResult == null)">
                        <MudIcon Icon="@Icons.Material.Filled.Save" Class="mr-1" /> Save Filter
                    </MudButton>
                    <MudSpacer />
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="ExpandAll">Expand All</MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="CollapseAll">Collapse All</MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="OpenFeatureDialog" Disabled="@(historyResult == null)">Select Features</MudButton>
                    @if (selectedFeatureNames.Any())
                    {
                        <MudTooltip Text="@string.Join(", ", selectedFeatureNames)">
                            <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">
                                Filter active: @selectedFeatureNames.Count feature(s)
                            </MudChip>
                        </MudTooltip>
                    }
                </div>
                @if (isTriageMode)
                {
                    <div class="d-flex gap-3 align-center mt-2">
                        <MudSwitch T="bool" Dense="true" Color="Color.Primary"
                                   Value="hideFlakyTests"
                                   ValueChanged="@(async (bool v) => { hideFlakyTests = v; historyResult = await BuildTriageHistoryResultAsync(); })">Hide flaky</MudSwitch>
                        <MudSwitch T="bool" Dense="true" Color="Color.Primary"
                                   Value="hideInfrastructureIssues"
                                   ValueChanged="@(async (bool v) => { hideInfrastructureIssues = v; historyResult = await BuildTriageHistoryResultAsync(); })">Hide infra/setup</MudSwitch>
                        <MudSwitch T="bool" Dense="true" Color="Color.Primary"
                                   Value="hideAcknowledgedFailures"
                                   ValueChanged="@(async (bool v) => { hideAcknowledgedFailures = v; historyResult = await BuildTriageHistoryResultAsync(); })">Hide acknowledged</MudSwitch>
                    </div>
                }
            </MudPaper>

            @* Stats Section *@
            @if (historyResult != null)
            {
                @if (isTriageMode && triageResult != null)
                {
                    <MudPaper Class="mb-4 pa-3" Style="@GetTriageBannerStyle()">
                        <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween" Style="gap:1rem; flex-wrap:wrap;">
                            <div>
                                <MudText Typo="Typo.subtitle1" Style="font-weight:700;">What changed vs selected builds</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    @triageResult.TodayBuildId (@GetBuildDisplayTime(triageResult.TodayBuildId)) vs @GetBaselineSummaryText()
                                </MudText>
                                <MudText Typo="Typo.caption" Color="@(triageResult.IsRunComplete ? Color.Success : Color.Warning)">
                                    @triageResult.CompletenessMessage
                                </MudText>
                            </div>
                            <div style="display:flex; gap:0.5rem; flex-wrap:wrap; align-items:center;">
                                <MudChip T="string"
                                         Color="Color.Error"
                                         Variant="@(selectedTriageSummaryFilter == TriageSummaryFilter.NewFailures ? Variant.Filled : Variant.Outlined)"
                                         OnClick="@(async () => await SetTriageSummaryFilter(TriageSummaryFilter.NewFailures))"
                                         Style="cursor:pointer;">New failures: @triageVisibleFailureCount</MudChip>
                                <MudChip T="string"
                                         Color="Color.Success"
                                         Variant="@(selectedTriageSummaryFilter == TriageSummaryFilter.FixedTests ? Variant.Filled : Variant.Outlined)"
                                         OnClick="@(async () => await SetTriageSummaryFilter(TriageSummaryFilter.FixedTests))"
                                         Style="cursor:pointer;">Fixed: @triageResult.FixedTests.Count</MudChip>
                                <MudChip T="string"
                                         Color="Color.Warning"
                                         Variant="@(selectedTriageSummaryFilter == TriageSummaryFilter.StillFailing ? Variant.Filled : Variant.Outlined)"
                                         OnClick="@(async () => await SetTriageSummaryFilter(TriageSummaryFilter.StillFailing))"
                                         Style="cursor:pointer;">Still failing: @triageResult.StillFailing.Count</MudChip>
                                <MudChip T="string"
                                         Color="@(triageResult.MissingConfigurations.Count == 0 ? Color.Success : Color.Warning)"
                                         Variant="@(selectedTriageSummaryFilter == TriageSummaryFilter.MissingConfigurations ? Variant.Filled : Variant.Outlined)"
                                         OnClick="@(async () => await SetTriageSummaryFilter(TriageSummaryFilter.MissingConfigurations))"
                                         Style="cursor:pointer;">Missing configs: @triageResult.MissingConfigurations.Count</MudChip>
                            </div>
                        </MudStack>
                    </MudPaper>
                }

                @if (!isTriageMode)
                {
                <MudGrid Class="mb-4">
                    <MudItem xs="12" sm="6" md="2">
                        <MudCard Class="slim-card" Variant="Variant.Outlined">
                            <MudCardContent>
                                <MudText Typo="Typo.caption" Color="Color.Default">Latest Run</MudText>
                                <MudText Typo="Typo.h6">@historyResult.LatestBuildId</MudText>
                                <MudText Typo="Typo.caption">@historyResult.LatestBuildTime.ToString("MM/dd/yyyy HH:mm")</MudText>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>

                    <MudItem xs="12" sm="6" md="2">
                        <MudCard Class="slim-card" Variant="Variant.Outlined">
                            <MudCardContent>
                                <MudText Typo="Typo.caption" Color="Color.Default">Total Tests</MudText>
                                <MudText Typo="Typo.h6">@historyResult.TotalTests</MudText>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>

                    <MudItem xs="12" sm="6" md="2">
                        <MudCard Class="slim-card" Variant="Variant.Outlined">
                            <MudCardContent>
                                <MudText Typo="Typo.caption" Color="Color.Default">Passed</MudText>
                                <MudText Typo="Typo.h6" Color="Color.Success">@historyResult.PassedTests (@historyResult.PassRatePercentage.ToString("F1")%)</MudText>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>

                    <MudItem xs="12" sm="6" md="2">
                        <MudCard Class="slim-card" Variant="Variant.Outlined" Style="cursor: pointer;" @onclick="ToggleFailedFilter">
                            <MudCardContent>
                                <MudText Typo="Typo.caption" Color="Color.Default">Failed</MudText>
                                <MudText Typo="Typo.h6" Color="Color.Error">@historyResult.FailedTests</MudText>
                                <MudText Typo="Typo.caption" Style="font-size: 0.75rem; color: #999; margin-top: 4px;">@(showOnlyFailed ? "✓ Filtered" : "Click to filter")</MudText>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>

                    <MudItem xs="12" sm="6" md="2">
                        <MudCard Class="slim-card" Variant="Variant.Outlined">
                            <MudCardContent>
                                <MudText Typo="Typo.caption" Color="Color.Default">Skipped</MudText>
                                <MudText Typo="Typo.h6">@historyResult.SkippedTests</MudText>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                </MudGrid>
                }

                @* Hierarchical Tree View *@
                <MudPaper Class="pa-4">
                    @if (isTriageMode && selectedTriageSummaryFilter == TriageSummaryFilter.MissingConfigurations)
                    {
                        var missingConfigurations = GetFilteredMissingConfigurations();
                        @if (missingConfigurations.Count == 0)
                        {
                            <MudText Color="Color.Default" Typo="Typo.body2">No missing configurations for the selected comparison.</MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.subtitle2" Class="mb-2">Configurations missing from @triageResult?.TodayBuildId</MudText>
                            <MudChipSet T="string">
                                @foreach (var configId in missingConfigurations)
                                {
                                    <MudChip T="string" Color="Color.Warning" Variant="Variant.Outlined">@ConfigurationLabelHelper.GetConfigurationLabel(configId)</MudChip>
                                }
                            </MudChipSet>
                        }
                    }
                    else if (historyResult.TotalTests == 0 && !historyResult.HierarchyNodes.Any(n => n.Children.Count > 0))
                    {
                        <MudText Color="Color.Default" Typo="Typo.body2">@(isTriageMode ? GetEmptyTriageFilterMessage() : "No test results found for selected configuration.")</MudText>
                    }
                    else
                    {
                        <div class="table-container" style="overflow-x: auto;">
                            @* Render hierarchy tree with filtering *@
                            @foreach (var domainNode in historyResult.HierarchyNodes)
                            {
                                var filtered = GetFilteredNode(domainNode);
                                @if (filtered != null)
                                {
                                    <HierarchyTreeView Node="filtered" 
                                                       HistoryColumns="historyResult.HistoryColumns"
                                                       OnTestSelected="@((testInfo) => SelectTest(testInfo))"
                                                       OnNodeAction="@OnNodeAction" />
                                }
                            }
                        </div>
                    }
                </MudPaper>
            }
            else if (isLoading)
            {
                <MudContainer Class="d-flex justify-center align-center" style="min-height: 400px;">
                    <MudProgressCircular Size="Size.Large" Indeterminate="true" />
                </MudContainer>
            }
            else if (selectedConfigurations.Any())
            {
                <MudAlert Severity="Severity.Info">Select configurations and click Refresh to load data.</MudAlert>
            }
        </MudItem>
    </MudGrid>
</MudContainer>

@if (showConfigurationDialog)
{
    <div class="modal-backdrop fade show" style="display: block; z-index: 9998;"></div>
    <div class="modal fade show" style="display: block; z-index: 9999;" role="dialog">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Select Configuration (@configurationMetadata.Count available)</h5>
                    <button type="button" class="btn-close" @onclick="() => showConfigurationDialog = false"></button>
                </div>
                <div class="modal-body">
                    <input type="text" class="form-control mb-3" placeholder="Search configurations..." 
                           @bind="searchText" @bind:event="oninput" />
                    
                    <div style="max-height: 500px; overflow-y: auto;">
                        @foreach (var configMeta in GetFilteredConfigurations())
                        {
                            <div style="padding: 12px; cursor: pointer; background-color: @(selectedConfigurations.Contains(configMeta.Id) ? "#e3f2fd" : "transparent"); border-bottom: 1px solid #eee; display: flex; justify-content: space-between; align-items: center;"
                                 @onclick="@(() => ToggleConfigurationFromDialog(configMeta.Id))">
                                <div style="flex: 1;">
                                    <div style="font-weight: 500;">@ConfigurationLabelHelper.GetConfigurationLabel(configMeta.Id)</div>
                                    <div style="font-size: 0.85rem; color: #666; margin-top: 2px;">Last updated: @configMeta.LastUpdateDisplay</div>
                                </div>
                                @if (selectedConfigurations.Contains(configMeta.Id))
                                {
                                    <span style="color: #1976d2; font-size: 1.2rem;">✓</span>
                                }
                            </div>
                        }
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-primary" @onclick="ApplyConfigurationSelection">Apply</button>
                    <button type="button" class="btn btn-secondary" @onclick="() => showConfigurationDialog = false">Cancel</button>
                </div>
            </div>
        </div>
    </div>
}

@if (showFeatureDialog)
{
    <FeatureSelectionModal FeatureGroups="featureGroups"
                           SelectedFeatures="selectedFeatureNames"
                           OnApply="ApplyFeatureSelection"
                           OnCancel="CloseFeatureDialog" />
}

@* Test Details Modal *@
<TestDetailsModal IsOpen="@showTestDetailsDialog" 
                  TestResult="@GetSelectedTestResult()"
                  BuildId="@GetSelectedBuildId()"
                  History="@GetTestHistory()"
                  CurrentWindowBuildIds="@GetCurrentWindowBuildIds()"
                  CanAcknowledge="@CanAcknowledgeSelectedTest()"
                  IsAcknowledgedEvaluator="@IsSelectedTestAcknowledged"
                  OnAcknowledge="@ToggleSelectedTestAcknowledgement"
                  OnClose="@CloseTestDetails" />

@* Save Filter Dialog *@
<SaveFilterDialog IsOpen="@showSaveFilterDialog" 
                  IsOpenChanged="@((bool value) => showSaveFilterDialog = value)"
                  CurrentFilter="@GetCurrentFilterState()"
                  OnFilterSaved="OnFilterSaved"
                  DefaultUsername="@currentUsername" />

@code {
    [SupplyParameterFromQuery(Name = "config")]
    public string? ConfigFromUrl { get; set; }
    
    [SupplyParameterFromQuery(Name = "builds")]
    public int? BuildsFromUrl { get; set; }

    [SupplyParameterFromQuery(Name = "filterId")]
    public int? FilterIdFromUrl { get; set; }

    [SupplyParameterFromQuery(Name = "feature")]
    public string? FeatureFromUrl { get; set; }

    [SupplyParameterFromQuery(Name = "mode")]
    public string? ModeFromUrl { get; set; }

    [SupplyParameterFromQuery(Name = "currentBuild")]
    public string? CurrentBuildFromUrl { get; set; }

    [SupplyParameterFromQuery(Name = "baselineBuild")]
    public string? BaselineBuildsFromUrl { get; set; }

    [SupplyParameterFromQuery(Name = "triageFilter")]
    public string? TriageFilterFromUrl { get; set; }
    
    private List<string> availableConfigurations = new();
    private List<ConfigurationMetadata> configurationMetadata = new();
    private string selectedConfiguration = string.Empty;
    private HashSet<string> selectedConfigurations = new(StringComparer.OrdinalIgnoreCase);
    private ConfigurationHistoryResult? historyResult;
    private MorningTriageResult? triageResult;
    private int numberOfBuilds = 5;
    private bool isLoading = false;
    private string searchText = string.Empty;
    private bool isTriageMode;
    private bool showConfigurationDialog = false;
    private bool showOnlyFailed = false;
    private bool hideFlakyTests = false;
    private bool hideInfrastructureIssues = false;
    private bool hideAcknowledgedFailures = false;
    private SelectedTestInfo? selectedTestInfo = null;  // Track selected test with column info
    private bool showFeatureDialog = false;   // Controls feature selection dialog
    private bool showTestDetailsDialog = false;  // Controls test details modal
    private Dictionary<string, List<string>> featureGroups = new();  // Groups of features
    private HashSet<string> selectedFeatureNames = new(StringComparer.OrdinalIgnoreCase);  // Effective features for current configuration
    private HashSet<string> selectedFeatureGroups = new(StringComparer.OrdinalIgnoreCase);  // Cross-configuration group intent
    private HashSet<string> explicitFeatureSelections = new(StringComparer.OrdinalIgnoreCase);  // Explicit features not implied by groups
    private bool showSaveFilterDialog = false;  // Controls save filter dialog
    private LoadFilterDropdown? loadFilterDropdown;  // Reference to load filter dropdown
    private string currentUsername = "DefaultUser";  // Current user (can be from auth later)
    private int? lastAppliedFilterId;  // Tracks the last applied filter for sharing
    private bool featureFromUrlApplied = false;
    private string? lastFeatureFromUrl;
    private List<string> availableBuilds = new();
    private string selectedCurrentBuild = string.Empty;
    private HashSet<string> selectedBaselineBuilds = new(StringComparer.OrdinalIgnoreCase);
    private string baselineBuildSearch = string.Empty;
    private HashSet<string> flakyTestNames = new(StringComparer.OrdinalIgnoreCase);
    private string? flakySignature;
    private Dictionary<string, MorningTriageAcknowledgement> acknowledgementsById = new(StringComparer.OrdinalIgnoreCase);
    private int triageVisibleFailureCount;
    private TriageSummaryFilter selectedTriageSummaryFilter = TriageSummaryFilter.NewFailures;

    // Expand All protection
    private const int MAX_EXPAND_ALL_NODES = 5000;

    protected override async Task OnInitializedAsync()
    {
        isTriageMode = string.Equals(ModeFromUrl, "triage", StringComparison.OrdinalIgnoreCase)
            || new Uri(NavigationManager.Uri).AbsolutePath.TrimEnd('/').Equals("/morning-triage", StringComparison.OrdinalIgnoreCase);

        await LoadAvailableConfigurations();
        availableBuilds = (await ConfigHistoryService.GetAvailableBuildsAsync())
            .OrderByDescending(BuildNumberExtractor.ExtractBuildNumber)
            .ToList();

        await LoadFeatureSelectionPreferencesAsync();

        ApplyTriageSummaryFilterFromUrl();

        // Apply saved filter from URL (if provided)
        var filterApplied = await ApplyFilterFromUrlAsync();

        // Load from URL parameters if present (has priority)
        if (!string.IsNullOrEmpty(ConfigFromUrl))
        {
            var parsedConfigs = ConfigFromUrl
                .Split(new[] { ',', '|' }, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Where(availableConfigurations.Contains)
                .ToHashSet(StringComparer.OrdinalIgnoreCase);
            if (parsedConfigs.Any())
            {
                selectedConfigurations = parsedConfigs;
                selectedConfiguration = parsedConfigs.First();
            }
        }
        else if (availableConfigurations.Count > 0 && string.IsNullOrEmpty(selectedConfiguration))
        {
            // Only set default if no URL parameter was provided
            selectedConfiguration = availableConfigurations[0];
            selectedConfigurations.Add(selectedConfiguration);
        }

        InitializeSelectedBuilds();

        // Load from URL parameters if present
        if (BuildsFromUrl.HasValue && BuildsFromUrl.Value >= 1 && BuildsFromUrl.Value <= 20)
        {
            numberOfBuilds = BuildsFromUrl.Value;
        }

        // Load data after selection is finalized
        if (!filterApplied && selectedConfigurations.Any())
        {
            await RefreshData();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        // Handle URL changes (browser back/forward)
        bool needsRefresh = false;
        
        isTriageMode = string.Equals(ModeFromUrl, "triage", StringComparison.OrdinalIgnoreCase)
            || new Uri(NavigationManager.Uri).AbsolutePath.TrimEnd('/').Equals("/morning-triage", StringComparison.OrdinalIgnoreCase);

        var requestedTriageFilter = ParseTriageSummaryFilter(TriageFilterFromUrl);
        if (requestedTriageFilter != selectedTriageSummaryFilter)
        {
            selectedTriageSummaryFilter = requestedTriageFilter;
            if (isTriageMode)
            {
                needsRefresh = true;
            }
        }

        if (!string.IsNullOrEmpty(ConfigFromUrl))
        {
            var requestedConfigs = ConfigFromUrl
                .Split(new[] { ',', '|' }, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Where(availableConfigurations.Contains)
                .ToHashSet(StringComparer.OrdinalIgnoreCase);
            if (requestedConfigs.Any() && !requestedConfigs.SetEquals(selectedConfigurations))
            {
                selectedConfiguration = requestedConfigs.First();
                selectedConfigurations = requestedConfigs;
                needsRefresh = true;
            }
        }

        if (!string.Equals(CurrentBuildFromUrl, selectedCurrentBuild, StringComparison.OrdinalIgnoreCase)
            || !string.Equals(BaselineBuildsFromUrl, string.Join(",", selectedBaselineBuilds), StringComparison.OrdinalIgnoreCase))
        {
            InitializeSelectedBuilds();
            needsRefresh = true;
        }
        
        if (BuildsFromUrl.HasValue && BuildsFromUrl.Value != numberOfBuilds)
        {
            numberOfBuilds = BuildsFromUrl.Value;
            needsRefresh = true;
        }

        if (!string.Equals(FeatureFromUrl, lastFeatureFromUrl, StringComparison.OrdinalIgnoreCase))
        {
            lastFeatureFromUrl = FeatureFromUrl;
            featureFromUrlApplied = false;
            if (historyResult != null)
            {
                ApplyFeatureFromUrlIfNeeded();
            }
        }
        
        if (needsRefresh)
        {
            await RefreshData();
        }
    }

    private async Task LoadAvailableConfigurations()
    {
        try
        {
            configurationMetadata = await ConfigHistoryService.GetConfigurationsWithMetadataAsync();
            availableConfigurations = configurationMetadata.Select(c => c.Id).ToList();
            // Don't set default here - let OnInitializedAsync handle it to respect URL params
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading configurations: {ex.Message}", Severity.Error);
        }
    }

    private void InitializeSelectedBuilds()
    {
        if (!string.IsNullOrWhiteSpace(CurrentBuildFromUrl) && availableBuilds.Contains(CurrentBuildFromUrl, StringComparer.OrdinalIgnoreCase))
        {
            selectedCurrentBuild = availableBuilds.First(build => string.Equals(build, CurrentBuildFromUrl, StringComparison.OrdinalIgnoreCase));
        }
        else
        {
            selectedCurrentBuild = availableBuilds.FirstOrDefault() ?? string.Empty;
        }

        selectedBaselineBuilds.Clear();
        if (!string.IsNullOrWhiteSpace(BaselineBuildsFromUrl))
        {
            foreach (var build in BaselineBuildsFromUrl.Split(new[] { ',', '|' }, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
            {
                if (availableBuilds.Contains(build, StringComparer.OrdinalIgnoreCase)
                    && !string.Equals(build, selectedCurrentBuild, StringComparison.OrdinalIgnoreCase))
                {
                    selectedBaselineBuilds.Add(availableBuilds.First(item => string.Equals(item, build, StringComparison.OrdinalIgnoreCase)));
                }
            }
        }

        if (selectedBaselineBuilds.Count == 0)
        {
            var fallback = availableBuilds.Skip(1).FirstOrDefault();
            if (!string.IsNullOrWhiteSpace(fallback))
            {
                selectedBaselineBuilds.Add(fallback);
            }
        }
    }

    private void EnsureSelectedBuilds()
    {
        if (!availableBuilds.Contains(selectedCurrentBuild, StringComparer.OrdinalIgnoreCase))
        {
            selectedCurrentBuild = availableBuilds.FirstOrDefault() ?? string.Empty;
        }

        selectedBaselineBuilds.RemoveWhere(build => !availableBuilds.Contains(build, StringComparer.OrdinalIgnoreCase)
            || string.Equals(build, selectedCurrentBuild, StringComparison.OrdinalIgnoreCase));

        if (selectedBaselineBuilds.Count == 0)
        {
            var fallback = availableBuilds.FirstOrDefault(build => !string.Equals(build, selectedCurrentBuild, StringComparison.OrdinalIgnoreCase));
            if (!string.IsNullOrWhiteSpace(fallback))
            {
                selectedBaselineBuilds.Add(fallback);
            }
        }
    }

    private List<string> GetBaselineBuildOptions()
    {
        return availableBuilds
