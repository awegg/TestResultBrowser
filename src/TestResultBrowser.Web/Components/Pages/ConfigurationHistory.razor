    private async Task ToggleSelectedTestAcknowledgement(TestResult testResult)
    {
        var targetNode = ResolveTriageNodeForTestResult(testResult) ?? selectedTestInfo?.TestNode;
        if (targetNode == null)
        {
            return;
        }

        var selectedNodeId = selectedTestInfo?.TestNode.NodeId;
        var selectedColumnIndex = selectedTestInfo?.ColumnIndex;

        await OnNodeAction(targetNode);

        if (historyResult?.HierarchyNodes == null || string.IsNullOrWhiteSpace(selectedNodeId) || !selectedColumnIndex.HasValue)
        {
            return;
        }

        var refreshedSelectedNode = FindNodeById(historyResult.HierarchyNodes, selectedNodeId);
        if (refreshedSelectedNode != null
            && string.Equals(refreshedSelectedNode.NodeId, selectedNodeId, StringComparison.OrdinalIgnoreCase))
        {
            selectedTestInfo = new SelectedTestInfo
            {
                TestNode = refreshedSelectedNode,
                ColumnIndex = selectedColumnIndex.Value
            };
        }
    }

    private HierarchyNode? ResolveTriageNodeForTestResult(TestResult testResult)
    {
        if (historyResult?.HierarchyNodes == null)
        {
            return null;
        }

        foreach (var nodeId in BuildCandidateNodeIds(testResult))
        {
            var node = FindNodeById(historyResult.HierarchyNodes, nodeId);
            if (node != null)
            {
                return node;
            }
        }

        return null;
    }

    private static HierarchyNode? FindNodeById(IEnumerable<HierarchyNode> nodes, string nodeId)
    {
        foreach (var node in nodes)
        {
            if (string.Equals(node.NodeId, nodeId, StringComparison.OrdinalIgnoreCase))
            {
                return node;
            }

            var childMatch = FindNodeById(node.Children, nodeId);
            if (childMatch != null)
            {
                return childMatch;
            }
        }

        return null;
    }

