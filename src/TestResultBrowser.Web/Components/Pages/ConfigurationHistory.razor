    private HierarchyNode BuildTriageDisplayTestNode(TriageDisplayRow row, List<string> buildIds)
    {
        var historyCells = buildIds
            .Select(buildId => TestDataService.GetTestResultFast(buildId, row.TestFullName, row.ConfigurationId))
            .Select(result => new HistoryCellData
            {
                Passed = result?.Status == TestStatus.Pass ? 1 : 0,
                Failed = result?.Status == TestStatus.Fail ? 1 : 0,
                Skipped = result?.Status == TestStatus.Skip ? 1 : 0,
                ReportDirectoryPath = result?.ReportDirectoryPath,
                SourceTestResult = result
            })
            .ToList();

        var latestKnownResult = historyCells.Select(cell => cell.SourceTestResult).FirstOrDefault(result => result != null);
        var node = new HierarchyNode
        {
            Name = latestKnownResult?.MethodName ?? row.TestFullName,
            NodeType = HierarchyNodeType.Test,
            NodeId = row.NodeId,
            IndentLevel = 2,
            TestFullName = row.TestFullName,
            ReportDirectoryPath = latestKnownResult?.ReportDirectoryPath,
            ErrorMessage = row.ErrorMessage,
            StackTrace = row.StackTrace,
            FirstErrorMessage = row.ErrorMessage,
            WorkItemReferences = WorkItemLinkService.GetTicketReferences(latestKnownResult?.WorkItemIds ?? new List<string>()),
            HistoryCells = historyCells,
            Badges = row.Badges,
            ActionLabel = row.ActionLabel,
            IsAcknowledged = row.IsAcknowledged
        };
        PopulateAggregateNode(node, buildIds.Count);
        return node;
    }

    private List<string> GetFilteredMissingConfigurations()
    {
        if (triageResult == null)
        {
            return new List<string>();
        }

        var missingConfigurations = triageResult.MissingConfigurations;
        var filterBySpecificConfigurations = selectedConfigurations.Any()
            && !selectedConfigurations.Contains(ConfigurationHistoryService.AllConfigurationsId, StringComparer.OrdinalIgnoreCase);

        return filterBySpecificConfigurations
            ? missingConfigurations.Where(selectedConfigurations.Contains).OrderBy(x => x, StringComparer.OrdinalIgnoreCase).ToList()
            : missingConfigurations.OrderBy(x => x, StringComparer.OrdinalIgnoreCase).ToList();
    }

