    private HierarchyNode BuildTriageTestNode(TriageRow row, List<string> buildIds)
    {
        var historyCells = buildIds
            .Select(buildId => TestDataService.GetTestResultFast(buildId, row.Failure.TestFullName, row.ConfigurationId))
            .Select(result => new HistoryCellData
            {
                Passed = result?.Status == TestStatus.Pass ? 1 : 0,
                Failed = result?.Status == TestStatus.Fail ? 1 : 0,
                Skipped = result?.Status == TestStatus.Skip ? 1 : 0,
                ReportDirectoryPath = result?.ReportDirectoryPath,
                SourceTestResult = result
            })
            .ToList();

        var latestKnownResult = historyCells.Select(cell => cell.SourceTestResult).FirstOrDefault(result => result != null);
        var badges = new List<HierarchyNodeBadge>();
        if (row.Failure.Category != MorningFailureCategory.Product)
        {
            badges.Add(new HierarchyNodeBadge { Text = row.Failure.Category == MorningFailureCategory.Setup ? "Setup" : "Infra", Tone = HierarchyBadgeTone.Warning });
        }

        if (GetAcknowledgement(row) is { } acknowledgement)
        {
            badges.Add(new HierarchyNodeBadge { Text = $"Ack: {acknowledgement.AcknowledgedBy}", Tone = HierarchyBadgeTone.Success });
        }

        var node = new HierarchyNode
        {
            Name = latestKnownResult?.MethodName ?? row.Failure.TestFullName,
            NodeType = HierarchyNodeType.Test,
            NodeId = BuildTriageNodeId(row),
            IndentLevel = 3,
            TestFullName = row.Failure.TestFullName,
            ReportDirectoryPath = latestKnownResult?.ReportDirectoryPath,
            ErrorMessage = row.Failure.ErrorMessage,
            StackTrace = row.Failure.StackTrace,
            FirstErrorMessage = row.Failure.ErrorMessage,
            WorkItemReferences = WorkItemLinkService.GetTicketReferences(latestKnownResult?.WorkItemIds ?? new List<string>()),
            HistoryCells = historyCells,
            Badges = badges,
            ActionLabel = "ack-toggle",
            IsAcknowledged = GetAcknowledgement(row) != null
        };
        PopulateAggregateNode(node, buildIds.Count);
        return node;
    }

    private List<HierarchyNodeBadge> BuildOwnerBadges(Dictionary<string, string> owners, string key)
    {
        return owners.TryGetValue(key, out var owner)
            ? new List<HierarchyNodeBadge> { new() { Text = owner, Tone = HierarchyBadgeTone.Info } }
            : new List<HierarchyNodeBadge>();
    }

    private void PopulateAggregateNode(HierarchyNode node, int buildCount)
    {
        if (node.Children.Count == 0)
        {
            var latest = node.HistoryCells.FirstOrDefault() ?? new HistoryCellData();
            node.LatestStats = new TestNodeStats { Passed = latest.Passed, Failed = latest.Failed, Skipped = latest.Skipped };
            return;
        }

        node.HistoryCells = Enumerable.Range(0, buildCount)
            .Select(index =>
            {
                var cell = new HistoryCellData();
                foreach (var child in node.Children)
                {
                    if (index >= child.HistoryCells.Count)
                    {
                        continue;
                    }

                    cell.Passed += child.HistoryCells[index].Passed;
                    cell.Failed += child.HistoryCells[index].Failed;
                    cell.Skipped += child.HistoryCells[index].Skipped;
                    cell.HookFailures += child.HistoryCells[index].HookFailures;
                }
                return cell;
            })
            .ToList();

        var latestCell = node.HistoryCells.FirstOrDefault() ?? new HistoryCellData();
        node.LatestStats = new TestNodeStats { Passed = latestCell.Passed, Failed = latestCell.Failed, Skipped = latestCell.Skipped };
        node.IsAcknowledged = node.Children.Count > 0 && node.Children.All(child => child.IsAcknowledged);
    }

    private async Task EnsureTriageFlakyTestsLoadedAsync()
    {
        if (triageResult == null)
        {
            return;
        }

        var signature = string.Join("\n", triageResult.NewFailures.Select(f => f.TestFullName).Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(name => name, StringComparer.OrdinalIgnoreCase));
        if (string.Equals(flakySignature, signature, StringComparison.Ordinal))
        {
            return;
        }

        var thresholds = BrowserOptions.Value.FlakyTestThresholds;
        var testNames = triageResult.NewFailures.Select(f => f.TestFullName).Distinct(StringComparer.OrdinalIgnoreCase).ToList();
        var reports = await Task.Run(() =>
        {
            var history = new List<TestResult>();
            foreach (var testName in testNames)
            {
                history.AddRange(TestDataService.GetTestResultsByTestName(testName)
                    .OrderByDescending(r => r.Timestamp)
                    .Take(thresholds.RollingWindowSize));
            }

            return FlakyTestDetectionService.DetectFlakyTests(history, Math.Clamp(thresholds.TriggerPercentage / 100.0, 0.0, 1.0), thresholds.RollingWindowSize);
        });

        flakyTestNames = reports.Select(report => report.TestFullName).ToHashSet(StringComparer.OrdinalIgnoreCase);
        flakySignature = signature;
    }

