    private static IEnumerable<string> BuildCandidateNodeIds(TestResult result)
    {
        yield return $"triage-test:{result.ConfigurationId}:{result.TestFullName}";
        yield return BuildStillFailingNodeId(result);
        yield return $"triage-fixed:{result.ConfigurationId}:{result.TestFullName}";
    }

    private TriageAcknowledgementTarget? ResolveAcknowledgementTarget(HierarchyNode node)
    {
        if (triageResult == null)
        {
            return null;
        }

        var newFailureRow = triageResult.NewFailures
            .SelectMany(failure => failure.AffectedConfigs.Select(configId => new TriageRow(failure, configId)))
            .FirstOrDefault(item => string.Equals(BuildTriageNodeId(item), node.NodeId, StringComparison.OrdinalIgnoreCase));

        if (newFailureRow != null)
        {
            return new TriageAcknowledgementTarget(
                BuildAcknowledgementId(newFailureRow),
                newFailureRow.Failure.TestFullName,
                newFailureRow.ConfigurationId,
                newFailureRow.Failure.FailureSignature,
                newFailureRow.Failure.DomainId,
                newFailureRow.Failure.FeatureId);
        }

        var stillFailingResult = triageResult.StillFailing
            .FirstOrDefault(result => string.Equals(BuildStillFailingNodeId(result), node.NodeId, StringComparison.OrdinalIgnoreCase));

        if (stillFailingResult == null)
        {
            return null;
        }

        return new TriageAcknowledgementTarget(
            BuildAcknowledgementId(stillFailingResult),
            stillFailingResult.TestFullName,
            stillFailingResult.ConfigurationId,
            FailureClassificationService.BuildFailureSignature(stillFailingResult),
            stillFailingResult.DomainId,
            stillFailingResult.FeatureId);
    }

    private async Task OnNodeAction(HierarchyNode node)
    {
        if (!isTriageMode || triageResult == null || node.NodeType != HierarchyNodeType.Test)
        {
            return;
        }

        var target = ResolveAcknowledgementTarget(node);
        if (target == null)
        {
            return;
        }

        if (acknowledgementsById.ContainsKey(target.Id))
        {
            await UserDataService.DeleteMorningTriageAcknowledgementAsync(target.Id);
            acknowledgementsById.Remove(target.Id);
        }
        else
        {
            var acknowledgement = await UserDataService.SaveMorningTriageAcknowledgementAsync(new MorningTriageAcknowledgement
            {
                Id = target.Id,
                TestFullName = target.TestFullName,
                ConfigurationId = target.ConfigurationId,
                FailureSignature = target.FailureSignature,
                DomainId = target.DomainId,
                FeatureId = target.FeatureId,
                AcknowledgedBy = currentUsername
            });
            acknowledgementsById[acknowledgement.Id] = acknowledgement;
        }

        historyResult = await BuildTriageHistoryResultAsync();
        StateHasChanged();
    }

    private ConfigurationHistoryResult MergeConfigurationHistoryResults(List<ConfigurationHistoryResult> histories)
    {
        if (histories.Count == 1)
        {
            return histories[0];
        }

        var merged = new ConfigurationHistoryResult
        {
            ConfigurationId = string.Join(", ", selectedConfigurations.OrderBy(x => x, StringComparer.OrdinalIgnoreCase)),
            LatestBuildId = histories.FirstOrDefault()?.LatestBuildId ?? string.Empty,
            LatestBuildTime = histories.FirstOrDefault()?.LatestBuildTime ?? DateTime.UtcNow,
            TotalTests = histories.Sum(history => history.TotalTests),
            PassedTests = histories.Sum(history => history.PassedTests),
            FailedTests = histories.Sum(history => history.FailedTests),
            SkippedTests = histories.Sum(history => history.SkippedTests),
            HistoryColumns = histories.FirstOrDefault()?.HistoryColumns ?? new List<HistoryColumn>(),
            HierarchyNodes = histories.SelectMany(history => history.HierarchyNodes).ToList()
        };

        return merged;
    }

