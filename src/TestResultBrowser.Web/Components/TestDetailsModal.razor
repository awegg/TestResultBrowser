@using TestResultBrowser.Web.Models
@using TestResultBrowser.Web.Services
@using TestResultBrowser.Web.Common
@using MudBlazor
@inject ITestReportUrlService TestReportUrlService
@inject IReportAssetService ReportAssetService
@inject ITestDataService TestDataService

@if (IsOpen && TestResult != null)
{
    <div class="modal-backdrop fade show" style="display: block; z-index: 9998;"></div>
    <div class="modal fade show" style="display: block; z-index: 9999;" role="dialog">
        <div class="modal-dialog modal-xl" style="max-height: 90vh; display: flex; flex-direction: column; max-width: 92vw;">
            <div class="modal-content" style="display: flex; flex-direction: column; max-height: 90vh;">
                <!-- Header -->
                <div class="modal-header">
                    <h5 class="modal-title">Test Details</h5>
                    <button type="button" class="btn-close" @onclick="Close"></button>
                </div>

                <!-- Body -->
                <div class="modal-body" style="overflow-y: auto; flex: 1; max-height: calc(90vh - 120px);">
                    <div class="test-details-grid">
                        <div class="test-details-main">
                            <!-- Build -->
                            <div class="mb-3">
                                <h6>Build</h6>
                                <p><strong>@(ActiveTest?.BuildId ?? BuildId ?? TestResult.BuildId ?? "Unknown")</strong></p>
                                @if (!string.IsNullOrEmpty(FlakyIndicatorText))
                                {
                                    <div style="font-size: 0.85rem; color: #64748b;">Flaky (last @FlakyWindow): @FlakyIndicatorText</div>
                                }
                            </div>

                            <!-- Test Name -->
                            <div class="mb-3">
                                <h6>@(TestResult.IsLifecycleHook ? "Hook" : "Test Name")</h6>
                                <p>@GetDisplayName(TestResult)</p>
                                @if (TestResult.IsLifecycleHook && !string.IsNullOrWhiteSpace(TestResult.LifecycleHookTarget))
                                {
                                    <div style="font-size: 0.9rem; color: #64748b;">Affected target: @TestResult.LifecycleHookTarget</div>
                                }
                            </div>

                            <!-- Error Message -->
                            @if (!string.IsNullOrEmpty(ActiveTest?.ErrorMessage))
                            {
                                <div class="mb-3">
                                    <h6>Error Message</h6>
                                    <div style="background-color: #fff3cd; padding: 10px; border-radius: 4px; border-left: 4px solid #ff6b6b;">
                                        <p style="margin: 0; white-space: pre-wrap; word-break: break-word;">@ActiveTest.ErrorMessage</p>
                                    </div>
                                </div>
                            }

                            <!-- Test History -->
                            @if (History?.Count > 0)
                            {
                                <div class="mb-3">
                                    <h6>Test History</h6>
                                    <table class="table table-sm table-striped" style="font-size: 0.85rem;">
                                        <thead>
                                            <tr>
                                                <th>Build</th>
                                                <th>Date</th>
                                                <th>Status</th>
                                                <th>Error Message</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in History)
                                            {
                                                <tr class="history-row @(IsActiveHistory(item) ? "is-active" : string.Empty)" @onclick="(() => SelectHistory(item))">
                                                    <td style="width: 120px;"><strong>@item.BuildId</strong></td>
                                                    <td style="width: 140px;">@item.Timestamp.ToString("MM/dd/yyyy HH:mm")</td>
                                                    <td style="width: 80px;">
                                                        @if (item.Status == TestStatus.Fail)
                                                        {
                                                            <span style="color: #dc3545;">Failed</span>
                                                        }
                                                        else if (item.Status == TestStatus.Skip)
                                                        {
                                                            <span style="color: #d4a017;">Skipped</span>
                                                        }
                                                        else
                                                        {
                                                            <span style="color: #28a745;">Passed</span>
                                                        }
                                                    </td>
                                                    <td style="word-break: break-word;">
                                                        @if (!string.IsNullOrEmpty(item.ErrorMessage))
                                                        {
                                                            <span>@item.ErrorMessage</span>
                                                        }
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }

                            <!-- Cross-Config Matrix -->
                            @if (_isLoadingCrossConfig)
                            {
                                <div class="mb-3">
                                    <h6>All Configurations</h6>
                                    <div class="cross-config-loading">Loading cross-configuration data...</div>
                                </div>
                            }
                            else if (_matrixBuildIds.Count > 0)
                            {
                                <div class="mb-3">
                                    <h6>All Configurations</h6>
                                    <div class="ccm-wrap">
                                        <table class="ccm-table">
                                            <thead>
                                                <tr>
                                                    <th class="ccm-config-header"></th>
                                                    @foreach (var bid in _matrixBuildIds)
                                                    {
                                                        <th class="ccm-build-header" title="@bid">@GetAbbreviatedBuild(bid)</th>
                                                    }
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var configId in _matrixConfigIds)
                                                {
                                                    var isCurrentConfig = string.Equals(configId, TestResult?.ConfigurationId, StringComparison.OrdinalIgnoreCase);
                                                    <tr>
                                                        <td class="ccm-config-label @(isCurrentConfig ? "ccm-config-current" : "")" title="@configId">
                                                            @configId
                                                            @if (isCurrentConfig) { <span class="cross-config-current-badge">current</span> }
                                                        </td>
                                                        @foreach (var bid in _matrixBuildIds)
                                                        {
                                                            var cellResult = _crossConfigMatrix.TryGetValue(configId, out var bmap) && bmap.TryGetValue(bid, out var cr) ? cr : null;
                                                            var dotClass = GetDotClass(cellResult);
                                                            var tip = GetCellTooltip(bid, cellResult);
                                                            var isActive = cellResult != null && IsActiveCrossConfig(cellResult);
                                                            <td class="ccm-cell @(isActive ? "ccm-cell-active" : "")" title="@tip" @onclick="(() => OnMatrixCellClick(cellResult))">
                                                                <span class="ccm-dot @dotClass">&#x25CF;</span>
                                                            </td>
                                                        }
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            }

                            <!-- Stack Trace -->
                            @if (!string.IsNullOrEmpty(ActiveTest?.StackTrace))
                            {
                                <div class="mb-3">
                                    <h6>Stack Trace</h6>
                                    <div style="background-color: #f8f9fa; padding: 10px; border-radius: 4px; max-height: 300px; overflow-y: auto;">
                                        <pre style="margin: 0; white-space: pre-wrap; word-break: break-word; font-size: 0.85rem;">@ActiveTest.StackTrace</pre>
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="test-details-media">
                            <h6>
                                Media / Report
                                @if (ActiveTest != null)
                                {
                                    <span class="media-meta">@ActiveTest.BuildId · @ActiveTest.Timestamp.ToString("MM/dd/yyyy HH:mm")</span>
                                }
                            </h6>
                            @if (IsLoadingAssets)
                            {
                                <div class="media-loading">Loading report assets...</div>
                            }
                            else if (HasMediaAssets)
                            {
                                <div class="media-assets">
                                    @if (!string.IsNullOrEmpty(AssetInfo?.ScreenshotUrl))
                                    {
                                        <img src="@AssetInfo!.ScreenshotUrl" alt="Test screenshot" />
                                    }
                                    @if (!string.IsNullOrEmpty(AssetInfo?.VideoUrl))
                                    {
                                        <video controls src="@AssetInfo!.VideoUrl"></video>
                                    }
                                </div>
                            }
                            else if (ActiveTest != null && string.IsNullOrEmpty(ActiveTest.ReportDirectoryPath))
                            {
                                <div class="media-empty">
                                    No report assets available for this test.
                                </div>
                            }
                            @if (HasMediaAssets)
                            {
                                <div class="media-links">
                                    @if (!string.IsNullOrEmpty(AssetInfo?.ScreenshotUrl))
                                    {
                                        <a class="btn btn-outline-secondary" target="_blank" href="@AssetInfo!.ScreenshotUrl">Open Screenshot</a>
                                    }
                                    @if (!string.IsNullOrEmpty(AssetInfo?.VideoUrl))
                                    {
                                        <a class="btn btn-outline-secondary" target="_blank" href="@AssetInfo!.VideoUrl">Open Video</a>
                                    }
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(ActiveTest?.ReportDirectoryPath))
                            {
                                <div class="media-preview">
                                    <iframe title="Test report preview" src="@GetReportUrl()" sandbox="allow-same-origin allow-scripts"></iframe>
                                </div>
                                <div class="mt-2">
                                    <a class="btn btn-outline-secondary" target="_blank" href="@GetReportUrl()">Open Full Report</a>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Footer -->
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="Close">Close</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public TestResult? TestResult { get; set; }

    [Parameter]
    public string? BuildId { get; set; }

    [Parameter]
    public List<TestResult>? History { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    [Parameter]
    public List<string>? CurrentWindowBuildIds { get; set; }

    private string? selectedHistoryId;
    private List<TestResult> _crossConfigResults = new();
    private bool _isLoadingCrossConfig;
    private List<string> _matrixBuildIds = new();
    private List<string> _matrixConfigIds = new();
    private Dictionary<string, Dictionary<string, TestResult>> _crossConfigMatrix = new(StringComparer.OrdinalIgnoreCase);
    private string? _lastCrossConfigTestName;
    private ReportAssetInfo? AssetInfo { get; set; }
    private bool IsLoadingAssets { get; set; }
    private string? lastAssetTestId;
    private const int FlakyWindow = 20;

    private TestResult? ActiveTest => GetActiveTestResult();

    private string? FlakyIndicatorText => BuildFlakyIndicator();

    private bool HasMediaAssets => AssetInfo != null &&
        (!string.IsNullOrEmpty(AssetInfo.ScreenshotUrl) || !string.IsNullOrEmpty(AssetInfo.VideoUrl));

    protected override async Task OnParametersSetAsync()
    {
        await LoadAssetsAsync();
        await LoadCrossConfigResultsAsync();
    }

    private string? BuildFlakyIndicator()
    {
        if (ActiveTest == null || History == null || History.Count == 0)
        {
            return null;
        }

        var configId = ActiveTest.ConfigurationId;
        if (string.IsNullOrWhiteSpace(configId))
        {
            return null;
        }

        var recent = History
            .Where(r => string.Equals(r.ConfigurationId, configId, StringComparison.OrdinalIgnoreCase))
            .OrderByDescending(r => r.Timestamp)
            .Take(FlakyWindow)
            .ToList();

        if (recent.Count == 0)
        {
            return null;
        }

        var total = recent.Count(r => r.Status != TestStatus.Skip);
        if (total == 0)
        {
            return null;
        }

        var failed = recent.Count(r => r.Status == TestStatus.Fail);
        var percent = (double)failed / total * 100.0;
        return $"{percent:F0}% ({failed}/{total})";
    }

    private async Task Close()
    {
        await OnClose.InvokeAsync();
    }

    private static string GetDisplayName(TestResult testResult)
    {
        if (!testResult.IsLifecycleHook)
        {
            return testResult.TestFullName;
        }

        var prefix = testResult.LifecycleHookType switch
        {
            TestLifecycleHookType.BeforeAll => "Setup failure (before all)",
            TestLifecycleHookType.BeforeEach => "Setup failure (before each)",
            TestLifecycleHookType.AfterEach => "Teardown failure (after each)",
            TestLifecycleHookType.AfterAll => "Teardown failure (after all)",
            _ => "Lifecycle hook failure"
        };

        return string.IsNullOrWhiteSpace(testResult.LifecycleHookTarget)
            ? prefix
            : $"{prefix} for {testResult.LifecycleHookTarget}";
    }

    private string GetReportUrl()
    {
        var reportPath = ActiveTest?.ReportDirectoryPath ?? string.Empty;
        return string.IsNullOrEmpty(reportPath)
            ? string.Empty
            : TestReportUrlService.GetReportUrl(reportPath) ?? string.Empty;
    }

    private async Task SelectHistory(TestResult item)
    {
        selectedHistoryId = item.Id;
        await LoadAssetsAsync();
    }

    private bool IsActiveHistory(TestResult item)
    {
        return string.Equals(selectedHistoryId, item.Id, StringComparison.OrdinalIgnoreCase);
    }

    private TestResult? GetActiveTestResult()
    {
        if (History == null || History.Count == 0)
        {
            return TestResult;
        }

        if (!string.IsNullOrEmpty(selectedHistoryId))
        {
            var match = History.FirstOrDefault(h => string.Equals(h.Id, selectedHistoryId, StringComparison.OrdinalIgnoreCase));
            if (match != null) return match;

            var crossMatch = _crossConfigResults.FirstOrDefault(r => string.Equals(r.Id, selectedHistoryId, StringComparison.OrdinalIgnoreCase));
            if (crossMatch != null) return crossMatch;
        }

        return History[0];
    }

    private int _lastWindowBuildIdsHash;

    private async Task LoadCrossConfigResultsAsync()
    {
        if (!IsOpen || TestResult == null)
        {
            _crossConfigResults = new();
            _matrixBuildIds = new();
            _matrixConfigIds = new();
            _crossConfigMatrix = new(StringComparer.OrdinalIgnoreCase);
            _lastCrossConfigTestName = null;
            return;
        }

        var testName = TestResult.TestFullName;
        var windowHash = CurrentWindowBuildIds?.Count > 0 
            ? CurrentWindowBuildIds.Aggregate(0, (h, b) => HashCode.Combine(h, StringComparer.OrdinalIgnoreCase.GetHashCode(b)))
            : 0;
        if (string.Equals(_lastCrossConfigTestName, testName, StringComparison.OrdinalIgnoreCase) 
            && _lastWindowBuildIdsHash == windowHash)
        {
            return;
        }

        _isLoadingCrossConfig = true;
        StateHasChanged();
        try
        {
            var allResults = await Task.Run(() => TestDataService.GetTestResultsByTestName(testName).ToList());

            if (CurrentWindowBuildIds?.Count > 0)
            {
                var buildSet = new HashSet<string>(CurrentWindowBuildIds, StringComparer.OrdinalIgnoreCase);
                allResults = allResults.Where(r => buildSet.Contains(r.BuildId)).ToList();
            }

            // One result per (build, config): prefer Fail > Skip > Pass, then latest timestamp
            allResults = allResults
                .GroupBy(r => $"{r.BuildId}|{r.ConfigurationId}")
                .Select(g => g
                    .OrderBy(r => r.Status == TestStatus.Fail ? 0 : r.Status == TestStatus.Skip ? 1 : 2)
                    .ThenByDescending(r => r.Timestamp)
                    .First())
                .ToList();

            _crossConfigResults = allResults;
            BuildCrossConfigMatrix(allResults, out _matrixBuildIds, out _matrixConfigIds, out _crossConfigMatrix);
            _lastCrossConfigTestName = testName;
            _lastWindowBuildIdsHash = windowHash;
        }
        finally
        {
            _isLoadingCrossConfig = false;
            StateHasChanged();
        }
    }
    private static void BuildCrossConfigMatrix(
        List<TestResult> results,
        out List<string> buildIds,
        out List<string> configIds,
        out Dictionary<string, Dictionary<string, TestResult>> matrix)
    {
        matrix = new Dictionary<string, Dictionary<string, TestResult>>(StringComparer.OrdinalIgnoreCase);
        foreach (var r in results)
        {
            if (!matrix.TryGetValue(r.ConfigurationId, out var buildMap))
            {
                buildMap = new Dictionary<string, TestResult>(StringComparer.OrdinalIgnoreCase);
                matrix[r.ConfigurationId] = buildMap;
            }
            buildMap[r.BuildId] = r;
        }

        buildIds = results
            .Select(r => r.BuildId)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderByDescending(b => BuildNumberExtractor.ExtractBuildNumber(b))
            .ToList();

        configIds = results
            .Select(r => r.ConfigurationId)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(c => c, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private static string GetAbbreviatedBuild(string buildId)
    {
        var num = BuildNumberExtractor.ExtractBuildNumber(buildId);
        return num > 0 ? $"#{num}" : buildId;
    }

    private static string GetDotClass(TestResult? result) => result?.Status switch
    {
        TestStatus.Fail => "ccm-dot-fail",
        TestStatus.Skip => "ccm-dot-skip",
        TestStatus.Pass => "ccm-dot-pass",
        _ => "ccm-dot-none"
    };

    private static string GetCellTooltip(string buildId, TestResult? result)
    {
        if (result == null) return $"{buildId}: Not run";
        var status = result.Status switch
        {
            TestStatus.Fail => "Failed",
            TestStatus.Skip => "Skipped",
            _ => "Passed"
        };
        var parts = new List<string> { $"{buildId}: {status}", result.ConfigurationId, result.Timestamp.ToString("yyyy-MM-dd HH:mm") };
        if (!string.IsNullOrEmpty(result.ErrorMessage))
            parts.Add(result.ErrorMessage.Length > 120 ? result.ErrorMessage[..120] + "\u2026" : result.ErrorMessage);
        return string.Join("\n", parts);
    }

    private bool IsActiveCrossConfig(TestResult item)
    {
        return string.Equals(selectedHistoryId, item.Id, StringComparison.OrdinalIgnoreCase);
    }

    private async Task OnMatrixCellClick(TestResult? result)
    {
        if (result == null) return;
        await SelectHistory(result);
    }

    private async Task LoadAssetsAsync()
    {
        if (!IsOpen || ActiveTest == null)
        {
            AssetInfo = null;
            IsLoadingAssets = false;
            return;
        }

        if (string.Equals(lastAssetTestId, ActiveTest.Id, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        IsLoadingAssets = true;
        StateHasChanged();
        try
        {
            AssetInfo = await ReportAssetService.GetAssetsAsync(ActiveTest);
            lastAssetTestId = ActiveTest.Id;
        }
        finally
        {
            IsLoadingAssets = false;
        }
    }
}

<style>
    .test-details-grid {
        display: grid;
        grid-template-columns: minmax(320px, 1.2fr) minmax(320px, 1fr);
        gap: 20px;
        align-items: start;
    }

    .test-details-media {
        position: sticky;
        top: 0;
    }

    .media-preview {
        border: 1px solid #e0e0e0;
        border-radius: 6px;
        overflow: hidden;
        background: #fff;
    }

    .media-preview iframe {
        width: 100%;
        height: 60vh;
        border: 0;
        background: #fff;
    }

    .media-empty {
        background: #f8f9fa;
        border: 1px dashed #c9c9c9;
        border-radius: 6px;
        padding: 16px;
        color: #666;
    }

    .media-loading {
        background: #f0f4f8;
        border: 1px solid #d8e1ea;
        border-radius: 6px;
        padding: 12px;
        color: #4b5563;
        font-size: 0.9rem;
        margin-bottom: 12px;
    }

    .media-assets {
        display: grid;
        gap: 12px;
        margin-bottom: 12px;
    }

    .media-assets img,
    .media-assets video {
        width: 100%;
        border-radius: 6px;
        border: 1px solid #e0e0e0;
        background: #fff;
    }

    .media-links {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 12px;
    }

    .media-meta {
        font-size: 0.78rem;
        font-weight: 500;
        color: #6b7280;
        margin-left: 6px;
    }

    .history-row {
        cursor: pointer;
    }

    .history-row.is-active {
        outline: 2px solid #5b67f2;
        outline-offset: -2px;
    }

    .cross-config-current-badge {
        display: inline-block;
        margin-left: 6px;
        padding: 1px 6px;
        font-size: 0.7rem;
        font-weight: 600;
        border-radius: 4px;
        background-color: #e0e7ff;
        color: #4338ca;
        vertical-align: middle;
    }

    .cross-config-loading {
        background: #f0f4f8;
        border: 1px solid #d8e1ea;
        border-radius: 6px;
        padding: 12px;
        color: #4b5563;
        font-size: 0.9rem;
    }

    .ccm-wrap {
        overflow-x: auto;
        max-height: 280px;
        overflow-y: auto;
    }

    .ccm-table {
        border-collapse: collapse;
        font-size: 0.82rem;
        white-space: nowrap;
    }

    .ccm-table thead th {
        position: sticky;
        top: 0;
        background: #f8f9fa;
        z-index: 1;
    }

    .ccm-config-header {
        min-width: 10px;
    }

    .ccm-build-header {
        width: 36px;
        text-align: center;
        font-weight: 600;
        padding: 4px 4px;
        color: #374151;
        font-size: 0.75rem;
        cursor: default;
    }

    .ccm-config-label {
        padding: 3px 10px 3px 0;
        text-overflow: ellipsis;
        overflow: hidden;
        max-width: 280px;
        white-space: nowrap;
        color: #374151;
        font-size: 0.82rem;
    }

    .ccm-config-label.ccm-config-current {
        font-weight: 600;
    }

    .ccm-cell {
        text-align: center;
        padding: 2px 3px;
        border-radius: 3px;
        cursor: default;
        transition: background 0.1s;
    }

    .ccm-cell:has(.ccm-dot-fail),
    .ccm-cell:has(.ccm-dot-skip),
    .ccm-cell:has(.ccm-dot-pass) {
        cursor: pointer;
    }

    .ccm-cell:hover {
        background: #e8eaf6;
    }

    .ccm-cell-active {
        background: #dde1fb;
        outline: 2px solid #5b67f2;
        outline-offset: -2px;
    }

    .ccm-dot {
        font-size: 0.95rem;
        line-height: 1;
        display: inline-block;
    }

    .ccm-dot-fail { color: #dc3545; }
    .ccm-dot-skip { color: #d4a017; }
    .ccm-dot-pass { color: #28a745; }
    .ccm-dot-none { color: #d1d5db; }

    @@media (max-width: 1000px) {
        .test-details-grid {
            grid-template-columns: 1fr;
        }

        .media-preview iframe {
            height: 45vh;
        }
    }
</style>
